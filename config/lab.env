# =============================================================================
# HomeSOClab - Central Lab Configuration (Single Source of Truth)
# =============================================================================
# This file is the authoritative definition of the lab's network, hypervisor,
# and VM topology. It is shell-sourceable (POSIX) and is consumed by the
# provisioning scripts in scripts/. Keep documentation and configs in sync
# with the values here.
#
# SECURITY NOTE: Do NOT commit real secrets to this file. Secrets (API tokens,
# root passwords) belong in config/secrets.env which is git-ignored. This file
# only contains non-sensitive topology data.
# =============================================================================

# ----------------------------------------------------------------------------
# Proxmox VE (Layer 1 - Hypervisor)
# ----------------------------------------------------------------------------
PVE_HOST="10.10.10.2"                 # Proxmox management IP (on Management VLAN)
PVE_NODE="pve01"                      # Proxmox node name
PVE_API_URL="https://10.10.10.2:8006/api2/json"
PVE_API_USER="root@pam"              # API user; prefer an API-token user in prod
PVE_STORAGE_VM="local-lvm"           # Block storage for VM disks (thin-LVM/ZFS)
PVE_STORAGE_ISO="local"              # Storage for ISO images / templates
PVE_BRIDGE="vmbr1"                    # VLAN-aware bridge carrying all lab VLANs

# ----------------------------------------------------------------------------
# VLAN / Network Topology (Layer 2 - Network Segmentation)
# ----------------------------------------------------------------------------
# Each VLAN is an isolated L2 broadcast domain. The firewall (pfSense/OPNsense)
# is the only inter-VLAN router and enforces the security policy between zones.

# --- Management VLAN: trusted plane for admin + SIEM/analyst access ---
VLAN_MGMT_ID=10
VLAN_MGMT_NAME="MGMT"
VLAN_MGMT_SUBNET="10.10.10.0/24"
VLAN_MGMT_GW="10.10.10.1"             # pfSense interface IP
VLAN_MGMT_DHCP_FROM="10.10.10.100"
VLAN_MGMT_DHCP_TO="10.10.10.199"

# --- Attacker VLAN: Kali/red-team box. Internet OK, home LAN BLOCKED ---
VLAN_ATTACK_ID=20
VLAN_ATTACK_NAME="ATTACKER"
VLAN_ATTACK_SUBNET="10.10.20.0/24"
VLAN_ATTACK_GW="10.10.20.1"
VLAN_ATTACK_DHCP_FROM="10.10.20.100"
VLAN_ATTACK_DHCP_TO="10.10.20.199"

# --- Victim VLAN: deliberately vulnerable endpoints. NO internet ---
VLAN_VICTIM_ID=30
VLAN_VICTIM_NAME="VICTIM"
VLAN_VICTIM_SUBNET="10.10.30.0/24"
VLAN_VICTIM_GW="10.10.30.1"
VLAN_VICTIM_DHCP_FROM="10.10.30.100"
VLAN_VICTIM_DHCP_TO="10.10.30.199"

# --- Monitoring VLAN: SPAN/mirror target + SIEM sensor (sniffing) ---
VLAN_MON_ID=99
VLAN_MON_NAME="MONITORING"
VLAN_MON_SUBNET="10.10.99.0/24"
VLAN_MON_GW="10.10.99.1"

# ----------------------------------------------------------------------------
# Upstream / Home network (treat as UNTRUSTED from the lab's perspective)
# ----------------------------------------------------------------------------
HOME_LAN_SUBNET="192.168.1.0/24"     # The existing home LAN - lab must not pivot here
WAN_MODE="dhcp"                       # pfSense WAN obtains address from home router

# ----------------------------------------------------------------------------
# Static service IPs (reserved, outside DHCP pools)
# ----------------------------------------------------------------------------
SIEM_IP="10.10.10.10"                # SIEM (e.g., Wazuh/Security Onion) mgmt UI
SIEM_SENSOR_MON_IP="10.10.99.10"     # SIEM sensor NIC on monitoring VLAN (SPAN sink)
ANALYST_WS_IP="10.10.10.20"          # Analyst workstation
DNS_RESOLVER="10.10.10.1"            # pfSense Unbound resolver
