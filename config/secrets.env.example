# =============================================================================
# HomeSOClab - SECRETS (template)
# -----------------------------------------------------------------------------
# Copy to config/secrets.env and fill in. secrets.env is git-ignored.
# Required only for API mode (SOCLAB_MODE=api). CLI mode (run on the node) uses
# the local root/PAM session and needs none of these.
# =============================================================================

# Proxmox API token (preferred over password). Create with:
#   pveum user token add svc-provision@pve automation --privsep 0
PVE_TOKEN_ID="svc-provision@pve!automation"
PVE_TOKEN_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Optional: only if you must use password auth instead of a token.
# PVE_API_PASSWORD="change-me"

# Optional: SSH key path injected into cloud-init endpoints.
# CI_SSH_PUBKEY="/root/.ssh/id_ed25519.pub"
