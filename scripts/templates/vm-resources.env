# =============================================================================
# HomeSOClab - VM resource allocation templates
# Sourced by the provisioning scripts. Tune to your host's capacity.
# Guidance: leave >=4 GB RAM + 2 cores for the Proxmox host itself.
# =============================================================================
#
# Sizing philosophy:
#   * Right-size, don't over-provision: lab VMs idle most of the time.
#   * pfSense is CPU-light but benefits from 2 vCPU under packet load + IDS.
#   * Kali wants RAM for tools (Burp, Metasploit) more than CPU.
#   * Victims are minimal; clone many small ones.
#   * SIEM (future phase) is the heavyweight: RAM + disk hungry.
#
# Fields: <ROLE>_CORES, <ROLE>_MEM (MB), <ROLE>_DISK (GB), <ROLE>_VLAN
# =============================================================================

# --- pfSense / OPNsense router-firewall ---
PFSENSE_CORES=2
PFSENSE_MEM=2048
PFSENSE_DISK=16
# pfSense has TWO NICs: WAN (vmbr0/home) + trunk (vmbr1, all VLANs)

# --- Kali Linux attacker ---
KALI_CORES=2
KALI_MEM=4096
KALI_DISK=40
KALI_VLAN=20

# --- Generic Linux victim/endpoint (placeholder for future endpoints) ---
ENDPOINT_LINUX_CORES=2
ENDPOINT_LINUX_MEM=2048
ENDPOINT_LINUX_DISK=20
ENDPOINT_LINUX_VLAN=30

# --- Generic Windows victim/endpoint (placeholder; needs more) ---
ENDPOINT_WIN_CORES=2
ENDPOINT_WIN_MEM=4096
ENDPOINT_WIN_DISK=60
ENDPOINT_WIN_VLAN=30

# --- SIEM sensor / server (provisioned in a later phase; sizing reference) ---
SIEM_CORES=4
SIEM_MEM=8192
SIEM_DISK=200
# SIEM has TWO NICs: mgmt (VLAN 10) + monitor/SPAN sink (VLAN 99, promiscuous)
